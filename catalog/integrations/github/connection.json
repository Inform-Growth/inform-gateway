{
  "transport": "stdio",
  "command": "mcp-server-github",
  "args": [],
  "env": {
    "GITHUB_TOKEN": "${GITHUB_TOKEN}"
  },
  "tools": {
    "allow": [
      "get_file_contents",
      "create_or_update_file",
      "list_files_in_repo",
      "search_repositories",
      "get_issue",
      "list_issues"
    ]
  }
}
