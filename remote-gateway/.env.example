# Remote Gateway Environment Variables
# Copy this file to .env and fill in your values.

# MCP Server
MCP_SERVER_NAME=[[ project_slug ]]
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# HubSpot CRM (proxied via gateway — operators need no local credentials)
# Get from: HubSpot → Settings → Integrations → Private Apps → Create a private app
# Recommended scopes: crm.objects.contacts.read/write, crm.objects.companies.read/write,
#   crm.objects.deals.read/write, crm.schemas.contacts.read, crm.schemas.companies.read,
#   crm.schemas.deals.read, tickets.read/write
# HUBSPOT_PRIVATE_APP_ACCESS_TOKEN=pat-na1-...

# Data Source API Keys
# STRIPE_API_KEY=sk_live_...
# SNOWFLAKE_ACCOUNT=...
# SNOWFLAKE_USER=...
# SNOWFLAKE_PASSWORD=...
# CRM_API_KEY=...
# CRM_BASE_URL=https://api.example.com

# GitHub (required for notes tools)
# GITHUB_TOKEN=github_pat_...
# GITHUB_REPO=owner/repo
# GITHUB_BRANCH=main
# NOTES_PATH=notes

# OpenAI (used by CI/CD QA agent)
# OPENAI_API_KEY=sk-...
