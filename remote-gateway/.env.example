# Remote Gateway Environment Variables
# Copy this file to .env and fill in your values.

# MCP Server
MCP_SERVER_NAME=[[ project_slug ]]
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# Admin dashboard token (REQUIRED in production — set to a real secret)
# ADMIN_TOKEN=

# GitHub (required for notes/issues tools — see remote-gateway/tools/notes.py)
# GITHUB_TOKEN=github_pat_...
# GITHUB_REPO=owner/repo
# GITHUB_BRANCH=main
# NOTES_PATH=notes

# OpenAI (used by CI/CD QA agent — see .github/workflows/qa_agent_review.yml)
# OPENAI_API_KEY=sk-...

# Proxied integrations — see remote-gateway/docs/integrations/ for the recipe
# per transport type, and remote-gateway/mcp_connections.example.json for one
# example connection per transport. Each integration's required env vars
# belong in mcp_connections.json's `env` block.
