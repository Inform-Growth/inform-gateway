# Remote Gateway Environment Variables
# Copy this file to .env and fill in your values.

# MCP Server
MCP_SERVER_NAME=[[ project_slug ]]
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# Exa (proxied via gateway — web search MCP)
# Get from: exa.ai → Dashboard → API Keys
# EXA_API_KEY=your_api_key_here

# Attio CRM (proxied via gateway — operators need no local credentials)
# Get from: Attio workspace settings → API Keys → Create API key (read+write scopes)
# ATTIO_API_KEY=your_api_key_here

# Apollo.io (direct REST API — no OAuth required)
# Get from: app.apollo.io → Settings → Integrations → API Keys
# APOLLO_API_KEY=your_api_key_here

# Google Workspace (Gmail + Calendar + Drive/Docs, proxied via gateway)
# OAuth client created in Google Cloud Console → APIs & Services → Credentials.
# First-time OAuth flow is browser-based (run locally; see README).
# WORKSPACE_MCP_CREDENTIALS_DIR points at a persistent location so cached
# tokens survive container restarts (Railway: mount the volume at /data and
# set this to /data/google-workspace-creds).
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-secret
# USER_GOOGLE_EMAIL=you@example.com
# WORKSPACE_MCP_CREDENTIALS_DIR=/data/google-workspace-creds

# Telemetry — set to a path on the persistent volume so tool-call history
# survives container restarts (default is data/telemetry.db, which is on the
# ephemeral container disk).
# TELEMETRY_DB_PATH=/data/telemetry.db

# Data Source API Keys
# STRIPE_API_KEY=sk_live_...
# SNOWFLAKE_ACCOUNT=...
# SNOWFLAKE_USER=...
# SNOWFLAKE_PASSWORD=...
# CRM_API_KEY=...
# CRM_BASE_URL=https://api.example.com

# GitHub (required for notes tools)
# GITHUB_TOKEN=github_pat_...
# GITHUB_REPO=owner/repo
# GITHUB_BRANCH=main
# NOTES_PATH=notes

# OpenAI (used by CI/CD QA agent)
# OPENAI_API_KEY=sk-...
